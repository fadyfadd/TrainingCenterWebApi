{
  "Serilog": {
    "MinimumLevel": {
      "Default" : "Information",
      "Override": {
        "TrainingCenterWebApi.Infrastructure" : "Debug"
      }      
    },
    
    "WriteTo": [
      {
        "Name": "Console"
      },
      {
        "Name": "File",
        "Args": {
          "path": "Logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 31,
          "outputTemplate": "[{Timestamp:HH:mm:ss} {Level:u3}] {Message:lj} {Properties:j}{NewLine}{Exception}"
        }
        
      }
    ]
  },
  "GeneralSettings": {
    "ConnectionString": "Host=localhost;Port=5432;Database=TrainingCenter;Username=postgres;Password=postgres",
    "CorsAllowedOrigins": "http://localhost:4200",
    "JwtSettings": {
      "ExpiryInMinutes": 120,
      "Key": "TY3vG5z8NqK2mP9xR4wF7sB1vC4xD6z9JmQ8wV3bN5x=",
      "Issuer": "https://auth.yourcompany.com",
      "Audience": "https://api.yourcompany.com/v1"
    }
  }
}